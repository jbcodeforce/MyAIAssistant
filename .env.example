# MyAIAssistant shared environment (repo root).
# Copy to .env and adjust values. Used by backend and agent_service.

# --- Backend ---
APP_NAME=MyAIAssistant Backend
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
NOTES_ROOT=docs/notes
AGENT_SERVICE_URL=http://localhost:8100
# CONFIG_FILE=./config.yaml

# --- Agent service ---
AGENT_SERVICE_PORT=8100
MYAI_BACKEND_URL=http://localhost:8000
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=llama3.2
LLM_API_KEY=no-key
VS_DB_URL=./data/vs.db
AI_DB_FILE=./data/memory.db
KNOWLEDGE_EMBEDDER_MODEL=nomic-embed-text
# AGENT_CONFIG_DIR=agent_service/agents/config
# AGNO_DEBUG=1
# TRACE_LLM_PROMPT=1
